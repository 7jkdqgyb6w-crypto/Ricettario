<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ricettario Piccotti — CMS prototipo build4</title>
  {% if site_css_exists %}<link rel="stylesheet" href="/site/style.css">{% endif %}
  <link rel="stylesheet" href="{{ url_for('static', filename='cms.css') }}">
  <script defer src="{{ url_for('static', filename='cms.js') }}"></script>
</head>
<body class="cms-body">
  <header class="cms-topbar">
    <div>
      <h1 class="cms-title">Ricettario Piccotti — CMS prototipo build4</h1>
      <p class="cms-subtle">Root attuale: <code>{{ site_root }}</code></p>
    </div>
    <div class="cms-topbar-actions">
      <button id="saveButton" disabled>Salva ricetta</button>
    </div>
  </header>

  <main class="cms-app-layout">
    <aside class="cms-sidebar cms-sidebar-left">
      <div class="cms-side-head">
        <h2 class="cms-side-title">Ricette</h2>
        <div class="cms-side-count" id="recipesCount"></div>
      </div>
      <div id="recipesList" class="recipes-list"></div>
    </aside>

    <section class="cms-editor-shell">
      <div id="emptyState" class="cms-empty-state">Seleziona una ricetta.</div>

      <form id="recipeForm" class="recipe-form hidden" onsubmit="return false;">
        <div class="cms-preview-card cms-editor-outline cms-title-wrap">
          <label class="cms-field-label">Titolo</label>
          <input id="titolo" name="titolo" class="title-input" type="text">
        </div>

        <div class="meta-grid cms-editor-outline cms-meta-edit-wrap">
          <div class="cms-meta-banner">Metadati del CMS</div>
          <div class="meta-card cms-meta-edit"><strong>Autore</strong><span><input id="autore" type="text"></span></div>
          <div class="meta-card cms-meta-edit"><strong>Categoria</strong><span><input id="categoria" type="text"></span></div>
          <div class="meta-card cms-meta-edit"><strong>Origine</strong><span><input id="origine" type="text"></span></div>
          <div class="meta-card cms-meta-edit"><strong>Fonte</strong><span><input id="fonte" type="text"></span></div>
        </div>

        <section class="lead cms-edit-section">
          <h2>Introduzione e contesto</h2>
          <div class="cms-editor-hint">Sezione modificabile. Il contenuto usa lo stile del sito; la cornice azzurra è del CMS.</div>
          <div id="editorIntroduzione" class="cms-rich-editor" contenteditable="true"></div>
        </section>

        <section class="block cms-edit-section">
          <h2>Ingredienti</h2>
          <div class="cms-editor-hint">Tabella ingredienti del CMS.</div>
          <div class="table-wrap">
            <table class="recipe-table ingredients-editor">
              <thead>
                <tr><th>Ingrediente</th><th>Quantità</th><th>Unità</th><th>Note</th><th></th></tr>
              </thead>
              <tbody id="ingredientsBody"></tbody>
            </table>
          </div>
          <button id="addIngredientRow" type="button" class="cms-secondary">Aggiungi riga</button>
        </section>

        <section class="block cms-edit-section">
          <h2>Preparazione</h2>
          <div class="cms-editor-hint">Sezione modificabile.</div>
          <div id="editorPreparazione" class="cms-rich-editor" contenteditable="true"></div>
        </section>

        <section class="notes cms-edit-section">
          <h2>Note e osservazioni</h2>
          <div class="cms-editor-hint">Sezione modificabile.</div>
          <div id="editorNote" class="cms-rich-editor" contenteditable="true"></div>
        </section>
      </form>
    </section>

    <aside class="cms-sidebar cms-sidebar-right">
      <h2 class="cms-side-title">Immagini</h2>
      <div class="cms-upload-box">
        <input id="imageUpload" type="file" accept=".jpg,.jpeg,.png,.webp">
        <button id="uploadButton" type="button" disabled>Carica immagine</button>
      </div>
      <p class="cms-subtle">Click su una miniatura per inserirla nel punto del cursore nella sezione attiva.</p>
      <div id="imagesPanel" class="images-panel"></div>
    </aside>
  </main>
</body>
</html>
