</footer><div class="recipe-search-overlay" id="recipeSearchOverlay" aria-hidden="true">
  <div class="recipe-search-backdrop js-site-search-close"></div>
  <section class="recipe-search-dialog" role="dialog" aria-modal="true" aria-labelledby="recipeSearchTitle">
    <button class="recipe-search-close js-site-search-close" type="button" aria-label="Chiudi">×</button>
    <h2 id="recipeSearchTitle">Cerca nel ricettario</h2>
    <form id="recipeSearchForm" action="ricette.html" method="get">
      <input id="recipeSearchInput" name="q" class="recipe-search-input" type="search" placeholder="Titolo, ingrediente, luogo…" autocomplete="off">
      <p class="recipe-search-hint">Inserisci un termine: l’indice Ricette si aprirà già filtrato.</p>
      <div class="recipe-search-actions"><button class="recipe-search-submit" type="submit">Cerca</button><p class="recipe-search-count" id="recipeSearchCount" aria-live="polite"></p></div>
    </form>
  </section>
</div>
<script id="index-term-search-submit-script">
(function(){
  function initIndexTermSearchSubmit(){
    var form=document.getElementById('recipeSearchForm');
    var input=document.getElementById('recipeSearchInput');
    if(!form||!input) return;
    form.addEventListener('submit',function(ev){
      var q=(input.value||'').replace(/\s+/g,' ').trim();
      if(!q){ev.preventDefault();input.focus();return;}
      ev.preventDefault();
      window.location.href='ricette.html?q='+encodeURIComponent(q);
    });
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',initIndexTermSearchSubmit); else initIndexTermSearchSubmit();
})();
</script></div></main></div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const wrap = document.querySelector('.index-filter');
  if (!wrap) return;
  const buttons = wrap.querySelectorAll('.filter-btn');
  function apply(cat) {
    document.querySelectorAll('[data-cats]').forEach(item => {
      const cats = (item.getAttribute('data-cats') || '').split(' ').filter(Boolean);
      const show = (cat === 'tutte') || cats.includes(cat);
      item.style.display = show ? '' : 'none';
    });
    document.querySelectorAll('[data-filter-group]').forEach(group => {
      const visible = Array.from(group.querySelectorAll('[data-cats]')).some(el => el.style.display !== 'none');
      group.style.display = visible ? '' : 'none';
    });
    buttons.forEach(b => b.classList.toggle('is-active', b.dataset.cat === cat));
  }
  buttons.forEach(btn => btn.addEventListener('click', () => apply(btn.dataset.cat)));
  apply('tutte');
});
</script>

<script id="cms-editor-shortcut-script">
(function(){
  var lastRecipeHref = '';
  function recipeSlugFromHref(href){
    if(!href) return '';
    try{
      var u = new URL(href, window.location.href);
      var match = u.pathname.match(/\/ricette\/([^\/?#]+)\/?(?:index\.html)?$/i);
      return match ? decodeURIComponent(match[1]) : '';
    }catch(e){
      var m = String(href).match(/(?:^|\/)ricette\/([^\/?#]+)\/?(?:index\.html)?$/i);
      return m ? decodeURIComponent(m[1]) : '';
    }
  }
  function cmsEditorBaseUrl(){
    try{
      var configured = window.localStorage && window.localStorage.getItem('ricettario.cmsBaseUrl');
      if(configured) return configured.replace(/\/+$/, '');
    }catch(e){}
    var host = window.location.hostname;
    var port = window.location.port;
    if(port === '5000' || /\.app\.github\.dev$/i.test(host)) return window.location.origin;
    if(host === 'localhost' || host === '127.0.0.1' || host === '::1') return 'http://127.0.0.1:5000';
    return 'http://127.0.0.1:5000';
  }
  function rememberRecipeLink(link){
    if(!link) return;
    var href = link.getAttribute('href') || '';
    if(recipeSlugFromHref(href)) lastRecipeHref = href;
  }
  function activeRecipeSlug(){
    var active = document.activeElement && document.activeElement.closest ? document.activeElement.closest('a[href]') : null;
    var slug = recipeSlugFromHref(active && active.getAttribute('href'));
    return slug || recipeSlugFromHref(lastRecipeHref);
  }
  function openCmsEditorForSlug(slug){
    if(!slug) return;
    var url = cmsEditorBaseUrl() + '/?slug=' + encodeURIComponent(slug);
    var win = window.open(url, 'ricettarioCmsEditor');
    if(win){ try{ win.focus(); }catch(e){} }
  }
  document.addEventListener('mouseover', function(ev){ rememberRecipeLink(ev.target.closest && ev.target.closest('a[href]')); }, true);
  document.addEventListener('focusin', function(ev){ rememberRecipeLink(ev.target.closest && ev.target.closest('a[href]')); }, true);
  document.addEventListener('click', function(ev){ rememberRecipeLink(ev.target.closest && ev.target.closest('a[href]')); }, true);
  document.addEventListener('keydown', function(ev){
    var key = (ev.key || '').toLowerCase();
    if(!(ev.ctrlKey && ev.altKey && key === 'e')) return;
    var target = ev.target;
    if(target && (target.isContentEditable || /^(input|textarea|select)$/i.test(target.tagName || ''))) return;
    var slug = activeRecipeSlug();
    if(!slug) return;
    ev.preventDefault();
    openCmsEditorForSlug(slug);
  });
})();
</script>
<script id="site-footer-script">
(function(){
  function ensureLightbox(){
    var lb=document.querySelector('.site-lightbox');
    if(lb) return lb;
    lb=document.createElement('div');
    lb.className='site-lightbox';
    lb.innerHTML='<button class="site-lightbox-close" aria-label="Chiudi">×</button><figure class="site-lightbox-frame"><img class="site-lightbox-image" alt=""><figcaption class="site-lightbox-caption"></figcaption></figure>';
    lb.addEventListener('click', function(ev){
  // chiude su overlay, su X e anche sull'immagine (come index)
  if (
    ev.target === lb ||
    ev.target.classList.contains('site-lightbox-close') ||
    ev.target.classList.contains('site-lightbox-image')
  ) {
    lb.classList.remove('is-open');
  }
});
    document.addEventListener('keydown', function(ev){ if(ev.key==='Escape') lb.classList.remove('is-open'); });
    document.body.appendChild(lb);
    return lb;
  }
  function openLightbox(src, alt){
    var lb=ensureLightbox();
    var img=lb.querySelector('.site-lightbox-image');
    var cap=lb.querySelector('.site-lightbox-caption');
    img.src=src; img.alt=alt||'';
    if(cap) cap.textContent=alt||'';
    lb.classList.add('is-open');
  }
  function showCopyToast(){
    var oldToast=document.querySelector('.site-copy-toast');
    if(oldToast) oldToast.remove();
    var toast=document.createElement('div');
    toast.className='site-copy-toast';
    toast.textContent='URL copiato';
    document.body.appendChild(toast);
    setTimeout(function(){ if(toast && toast.parentNode) toast.parentNode.removeChild(toast); }, 1200);
  }
  document.addEventListener('DOMContentLoaded', function(){
    /* Indici: nessun QR nel footer. QR riservati alle singole ricette. */

    document.querySelectorAll('.js-print-link').forEach(function(a){
      a.addEventListener('click', function(ev){ ev.preventDefault(); window.print(); });
    });
    document.querySelectorAll('.js-qr-lightbox').forEach(function(a){
      a.addEventListener('click', function(ev){
        ev.preventDefault();
        openLightbox(a.getAttribute('href'), (a.querySelector('img')||{}).alt || 'QR della pagina');
      });
    });
    document.querySelectorAll('.index-editorial-card img').forEach(function(img){
      img.addEventListener('click', function(ev){
        ev.preventDefault();
        ev.stopPropagation();
        window.setTimeout(function(){
          openLightbox(img.currentSrc || img.src, img.alt || '');
        }, 0);
      });
    });
    document.querySelectorAll('.js-copy-link').forEach(function(a){
      a.addEventListener('click', async function(ev){
        ev.preventDefault();
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(window.location.href);
          } else {
            var ta=document.createElement('textarea');
            ta.value=window.location.href; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove();
          }
          showCopyToast();
        } catch(e) {}
      });
    });
  });
})();
</script>
</body>
</html>
