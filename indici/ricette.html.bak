<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Le ricette - Ricette (e altro) di Pierre</title>
<link rel="stylesheet" href="../style.css">
<style>
.index-page > .index-content{max-width:var(--reading);margin-left:auto;margin-right:auto;width:100%;}
.index-page > .index-content > h1{margin-bottom:1.2rem;}
.index-page .block,.index-page .lead,.index-page .index-section{max-width:100%;}
.index-filter{margin:0 0 1.5rem 0}
.index-filter h2{font-size:1.05rem;margin:0 0 .75rem 0}
.filter-buttons{display:flex;gap:.8rem;flex-wrap:wrap}
.filter-btn{border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.75rem 1.2rem;font:inherit;cursor:pointer}
.filter-btn.is-active{background:#222;color:#fff;border-color:#222}
.index-links li{margin:.25rem 0}
.index-category{padding-top:.7rem;border-top:1px solid var(--line);margin-bottom:1.4rem;}
.index-category h2{margin-bottom:.9rem;}
.recipe-index-list{display:grid;gap:1.6rem;}
.recipe-index-card{display:block;padding-top:1.2rem;border-top:1px solid var(--line);}
.recipe-index-card:first-child{border-top:0;padding-top:0;}
.recipe-index-media{display:block;width:100%;margin:0 0 1rem 0;}
.recipe-index-media a{display:block;width:100%;}
.recipe-index-media img{display:block;width:100%;max-width:100%;height:auto;box-shadow:none;background:#fff;}
.recipe-index-body h3{margin:0 0 .45rem;font-size:1.15rem;line-height:1.2;color:#566064;}
.recipe-index-body p{margin:0 0 .7rem;}
.recipe-index-meta{list-style:none;padding:0;margin:0;display:flex;flex-wrap:wrap;gap:.55rem 1.2rem;}
.recipe-index-meta li{margin:0;}
.index-page .index-category .home-secondary-list{grid-template-columns:repeat(auto-fit,minmax(18rem,1fr));gap:.38rem .7rem;align-items:start;}
.index-page .index-category .home-secondary-list li{min-width:0;}
.index-page .index-category .home-secondary-list a.has-recipe-thumb{display:grid;grid-template-columns:4.35rem minmax(0,1fr);gap:.55rem;align-items:center;height:auto;min-height:3.15rem;padding:.42rem .55rem;border:1px solid var(--line);background:rgba(255,255,255,0.34);box-shadow:none;}
.index-page .index-category .home-secondary-list a.has-recipe-thumb:hover{background:rgba(255,255,255,0.68);}
.recipe-list-thumb{display:block;width:4.35rem;aspect-ratio:1.618/1;overflow:hidden;background:#f4f1ed;align-self:center;}
.recipe-list-thumb img{display:block;width:100%;height:100%;object-fit:cover;box-shadow:none;background:#fff;}
.recipe-list-text{display:block;min-width:0;line-height:1.18;}
.recipe-list-text strong{display:block;color:#566064;font-size:.92rem;line-height:1.16;overflow-wrap:anywhere;}
.recipe-list-text span{display:block;margin-top:.12rem;color:var(--muted);font-size:.78rem;line-height:1.2;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
@media (min-width:1180px){
  .index-page .index-category .home-secondary-list{grid-template-columns:repeat(auto-fit,minmax(20rem,1fr));}
}
@media (max-width:520px){
  .index-page .index-category .home-secondary-list{grid-template-columns:1fr;gap:.34rem;}
  .index-page .index-category .home-secondary-list a.has-recipe-thumb{grid-template-columns:3.8rem minmax(0,1fr);gap:.5rem;padding:.38rem .48rem;min-height:2.85rem;}
  .recipe-list-thumb{width:3.8rem;}
}
.recipe-refine-panel{margin:0 0 1.5rem 0;padding:.45rem 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.recipe-refine summary{cursor:pointer;font-size:.95rem;color:#566064;}
.recipe-refine-grid{display:grid;gap:.7rem;margin:.75rem 0 0 0;}
.recipe-refine-group h2{font-size:.82rem;text-transform:uppercase;letter-spacing:.04em;margin:0 0 .35rem 0;color:#566064;}
.recipe-refine-buttons{display:flex;flex-wrap:wrap;gap:.35rem;}
.recipe-refine-btn{border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.28rem .58rem;font:inherit;font-size:.86rem;line-height:1.2;cursor:pointer;}
.recipe-refine-btn.is-active{background:#566064;color:#fff;border-color:#566064;}

.recipe-refine-group-allergens{position:relative;}
.recipe-allergen-picker{display:block;}
.recipe-allergen-picker > summary{display:inline-flex;align-items:center;gap:.35rem;border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.32rem .7rem;font:inherit;font-size:.86rem;line-height:1.2;cursor:pointer;color:#111;}
.recipe-allergen-panel{display:grid;grid-template-columns:repeat(auto-fit,minmax(13rem,1fr));gap:.35rem .8rem;margin:.55rem 0 0 0;padding:.75rem;border:1px solid var(--line);background:#fff;border-radius:.5rem;}
.recipe-allergen-option{display:flex;align-items:flex-start;gap:.45rem;font-size:.86rem;line-height:1.25;color:var(--text);}
.recipe-allergen-option input{margin-top:.08rem;accent-color:#566064;}
.recipe-allergen-source{margin:.45rem 0 0 0;font-size:.76rem;color:#566064;}
.recipe-allergen-source a{color:#5f86ad;font-weight:600;}
.recipe-refine-actions{margin:.55rem 0 0 0;}
.recipe-reset-btn{border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.28rem .62rem;font:inherit;font-size:.86rem;line-height:1.2;cursor:pointer;color:#566064;}
.recipe-reset-btn:hover{border-color:#566064;color:#222;}
.recipe-result-count{margin:.6rem 0 0 0;font-size:.9rem;color:#566064;}
.recipe-result-count strong,.recipe-search-count strong{font-weight:700;color:#222;}
.recipe-current-query{color:#566064;}
.recipe-clear-search{border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.18rem .52rem;font:inherit;font-size:.82rem;line-height:1.2;cursor:pointer;color:#566064;margin-left:.45rem;}
.recipe-clear-search:hover{border-color:#566064;color:#222;}
.site-header nav{display:flex;align-items:center;gap:1rem;flex-wrap:nowrap;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;margin-left:auto;justify-content:flex-end;}
.site-header nav::-webkit-scrollbar{display:none;width:0;height:0;}
.site-header nav a{white-space:nowrap;}
.site-header .index-nav-back{display:inline-flex !important;align-items:center;justify-content:center;width:28px;height:28px;font-size:24px;line-height:1;text-decoration:none;color:inherit;flex:0 0 auto;position:relative;top:-2px;visibility:visible !important;}
.site-header .index-nav-back:hover{text-decoration:none;}
.site-search-button{display:inline-flex;align-items:center;justify-content:center;border:0;background:transparent;color:inherit;padding:.15rem .1rem;cursor:pointer;vertical-align:middle;flex:0 0 auto;}
.site-search-button svg{width:1.08em;height:1.08em;stroke:currentColor;stroke-width:2;fill:none;display:block;}
.recipe-search-overlay{position:fixed;inset:0;z-index:2000;display:none;}
.recipe-search-overlay.is-open{display:block;}
.recipe-search-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.10);}
.recipe-search-dialog{position:fixed;top:4.8rem;right:2rem;width:min(410px,calc(100vw - 2rem));margin:0;padding:.95rem 1rem;background:#fff;border:1px solid #8b837b;box-shadow:0 18px 45px rgba(0,0,0,.22);border-radius:.45rem;}
.recipe-search-dialog h2{margin:0 2rem .55rem 0;font-size:1.05rem;}
.recipe-search-close{position:absolute;top:.45rem;right:.65rem;border:0;background:transparent;font:inherit;font-size:1.45rem;line-height:1;cursor:pointer;color:#566064;}
.recipe-search-input{box-sizing:border-box;width:100%;border:1px solid #9d948b;border-radius:.45rem;padding:.55rem .65rem;font:inherit;background:#fff;}
.recipe-search-hint{margin:.45rem 0 .65rem 0;font-size:.84rem;color:#566064;}
.recipe-search-actions{display:flex;align-items:center;justify-content:flex-start;gap:.7rem;margin:.55rem 0 0 0;}
.recipe-search-submit{display:inline-flex;align-items:center;justify-content:center;width:auto;min-width:5.8rem;border:1px solid #8b837b;background:#fff;border-radius:999px;padding:.32rem .78rem;font:inherit;font-size:.9rem;line-height:1.2;cursor:pointer;}
.recipe-search-submit:hover{border-color:#566064;}
.recipe-search-count{margin:0;font-size:.84rem;color:#566064;}
.index-editorial-card{display:grid;gap:.75rem;margin:.2rem 0 1rem 0;padding:.85rem;border:1px solid var(--line);background:rgba(255,255,255,.42);}
.index-editorial-card figure{margin:0;}
.index-editorial-card p{margin:0 0 .55rem 0;}
.index-editorial-html::after{content:"";display:block;clear:both;}
.index-editorial-html figure{margin:.2rem .7rem .7rem 0;display:inline-block;vertical-align:top;max-width:100%;box-sizing:border-box;}
.index-editorial-html img{display:block;max-width:100%;height:auto;box-shadow:none;background:#fff;cursor:zoom-in;}
.index-editorial-html figcaption{font-size:.84rem;color:#566064;margin-top:.25rem;line-height:1.25;}
.index-editorial-html figure.step-photo,.index-editorial-html figure.step-photo-large,.index-editorial-html figure.step-photo-left,.index-editorial-html figure.step-photo-right{display:block;margin:.35rem 0 .8rem 0;}
.index-editorial-html figure.step-photo-large{width:100%;}
.index-editorial-html figure.step-photo[data-align="center"],.index-editorial-html figure.step-photo-large[data-align="center"]{margin-left:auto;margin-right:auto;}
.index-editorial-html .image-row{display:flex;flex-wrap:wrap;align-items:flex-start;gap:.75rem;margin:.35rem 0 .9rem 0;clear:both;}
.index-editorial-html .image-row > figure{flex:0 1 auto;margin:0;}
@media (min-width:760px){
  .index-editorial-html figure.step-photo-right{float:right;clear:right;margin-left:1rem;}
  .index-editorial-html figure.step-photo-left{float:left;clear:left;margin-right:1rem;}
}
@media (max-width:640px){
  .index-editorial-html figure.step-photo,.index-editorial-html figure.step-photo-large,.index-editorial-html figure.step-photo-left,.index-editorial-html figure.step-photo-right{float:none !important;clear:both !important;width:100% !important;max-width:100% !important;margin:.35rem 0 .85rem 0 !important;}
  .index-editorial-html .image-row{display:block;}
  .index-editorial-html .image-row > figure{width:100% !important;max-width:100% !important;margin:.35rem 0 .85rem 0 !important;}
}
.index-editorial-html ul,.index-editorial-html ol{margin:.25rem 0 .75rem 1.35rem;line-height:1.28;}
.index-editorial-html li{margin:.08rem 0;}
.index-editorial-html .index-mini-table{width:100%;border-collapse:collapse;margin:.6rem 0;background:#fff;table-layout:fixed;}
.index-editorial-html .index-mini-table th,.index-editorial-html .index-mini-table td{border:1px solid var(--line);padding:.35rem .5rem;vertical-align:top;line-height:1.25;}
.index-editorial-html .index-mini-table th{background:rgba(255,255,255,.58);font-weight:700;}
.index-editorial-images{display:grid;grid-template-columns:repeat(auto-fit,minmax(7rem,1fr));gap:.55rem;}
.index-editorial-images img{width:100%;height:auto;box-shadow:none;background:#fff;cursor:zoom-in;}
.index-editorial-links{display:flex;flex-wrap:wrap;gap:.45rem .7rem;margin:.55rem 0 0 0;}
.index-editorial-link{display:inline-flex;border:1px solid #c9c1b8;background:#fff;border-radius:999px;padding:.25rem .62rem;font-size:.86rem;line-height:1.2;}
.index-editorial-link:hover{text-decoration:none;border-color:#566064;}
@media (max-width:760px){.site-header nav{gap:.32rem;margin-left:auto;justify-content:flex-end;}.site-header nav a{font-size:.95rem;letter-spacing:-.015em;}.site-header .index-nav-back{width:20px;height:22px;font-size:18px;top:-1px;}.site-header .site-search-button{padding:.05rem 0;}.site-header .site-search-button svg{width:.98em;height:.98em;}}
@media (max-width:640px){.recipe-search-dialog{top:4rem;right:1rem;left:1rem;width:auto;}}
</style>
</head>
