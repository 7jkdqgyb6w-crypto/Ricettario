#!/usr/bin/env python3
import subprocess, sys
from pathlib import Path

root = Path(sys.argv[1] if len(sys.argv) > 1 else '.')
for name in [
    'build_autore_html.py',
    'build_categorie_html.py',
    'build_ricette_html.py',
    'build_ingredienti_html.py',
    'build_fonti_html.py',
    'build_geografia_html.py',
]:
    subprocess.run([sys.executable, str(Path(__file__).with_name(name)), str(root)], check=True)
print('OK tutti gli indici')
