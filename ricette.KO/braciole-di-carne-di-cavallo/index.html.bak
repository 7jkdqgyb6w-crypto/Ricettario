}</style>
  <style id="recipe-lightbox-style">.recipe-lightbox-overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);display:flex;align-items:center;justify-content:center;padding:2rem;z-index:9999;cursor:zoom-out;}
.recipe-lightbox-overlay.is-hidden{display:none !important;}
.recipe-lightbox-frame{max-width:96vw;max-height:96vh;display:flex;flex-direction:column;gap:.75rem;align-items:center;}
.recipe-lightbox-frame img{display:block;max-width:96vw;max-height:88vh;width:auto;height:auto;box-shadow:0 8px 32px rgba(0,0,0,.45);background:#fff;}
.recipe-lightbox-caption{color:#fff;text-align:center;max-width:min(96vw,70rem);font-size:.95rem;line-height:1.35;}
main figure:not(.recipe-license) img{cursor:zoom-in;}</style>
</head>
<body>
<div class="page">
<header class="site-header">
  <a class="brand" href="../../index.html">Ricette (e altro) di Pierre</a>
