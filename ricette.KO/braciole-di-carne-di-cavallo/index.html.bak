  <style id="recipe-layout-style">.recipe-page{
  max-width: 100%;
}
.recipe-page > h1{
  margin-bottom: 1.2rem;
}
.recipe-page .recipe-content{
  width: 100%;
  max-width: min(100%, var(--reading));
}
.recipe-page .meta-grid,
.recipe-page .lead,
.recipe-page .block,
.recipe-page .notes,
.recipe-page .rp-license-wrap{
  max-width: min(100%, var(--reading));
}
