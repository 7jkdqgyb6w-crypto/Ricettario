  background: rgba(255,255,255,0.68);
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
  padding: 1.1rem 1.25rem;
}
.recipe-page .lead h2:first-child,
.recipe-page .notes h2:first-child,
.recipe-page .block h2:first-child{
