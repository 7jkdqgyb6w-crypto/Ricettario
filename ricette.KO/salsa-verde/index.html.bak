<main><h1>Salsa verde</h1><div class="meta-grid"><div class="meta-card"><strong>Autore</strong>Pierre Piccotti</div><div class="meta-card"><strong>Categoria</strong>salse e basi</div><div class="meta-card"><strong>Fonte</strong>Jacqueline Gibert</div></div><section class="block"><h2>Ingredienti</h2><table class="recipe-table"><thead><tr><th>Ingrediente</th><th>Quantità</th><th>Unità</th><th>Note</th></tr></thead><tbody><tr><td>prezzemolo</td><td>1</td><td>mazzo</td><td></td></tr><tr><td>d’aglio</td><td>3</td><td>spicchi</td><td></td></tr><tr><td>capperi</td><td>1</td><td>cucchiaio</td><td></td></tr><tr><td>alici sotto sale</td><td>7</td><td></td><td></td></tr><tr><td>mollica di pane imbevuto di latte</td><td>1</td><td>pugno</td><td></td></tr><tr><td>olio di oliva</td><td>1</td><td>bicchiere</td><td></td></tr><tr><td>aceto</td><td></td><td></td><td></td></tr><tr><td>sale</td><td></td><td></td><td></td></tr></tbody></table></section><section class="block"><h2>Preparazione</h2><ol class="steps"><li>Frullare il tutto molto bene.</li></ol></section><section class="photo-block"><h2>Immagini</h2><p>Spazio predisposto per la galleria fotografica locale della ricetta.</p></section></main>
