:root {
  --cms-bg: #f4f6fa;
  --cms-panel: #ffffff;
  --cms-line: #cfd7e6;
  --cms-accent: #225ea8;
  --cms-subtle: #667085;
}

body.cms-body {
  margin: 0;
  background: var(--cms-bg);
}

.cms-topbar,
.cms-topbar *,
.cms-sidebar,
.cms-sidebar *,
.cms-editor-hint,
.cms-meta-banner,
.cms-field-label,
.cms-subtle,
button,
input {
  font-family: Arial, Helvetica, sans-serif !important;
}

.cms-topbar {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
  padding: 1rem 1.25rem;
  background: #16324f;
  color: white;
}
.cms-title { margin: 0 0 .35rem 0; font-size: 1.25rem; color: white; }
.cms-subtle { margin: 0; color: #d7deea; font-size: .92rem; }
.cms-topbar code { color: #fff; background: rgba(255,255,255,.12); padding: .1rem .35rem; border-radius: .3rem; }
.cms-app-layout { display: grid; grid-template-columns: 280px minmax(0,1fr) 260px; gap: 1rem; padding: 1rem; }
.cms-sidebar, .cms-editor-shell { min-height: calc(100vh - 120px); }
.cms-sidebar {
  background: var(--cms-panel);
  border: 1px solid var(--cms-line);
  border-radius: 12px;
  padding: 1rem;
  overflow: auto;
}
.cms-editor-shell { overflow: auto; }
.cms-side-title { margin-top: 0; font-size: 1rem; }
.recipe-item { display:block; width:100%; text-align:left; margin:0 0 .4rem 0; padding:.6rem .75rem; border:1px solid var(--cms-line); border-radius:8px; background:white; cursor:pointer; }
.recipe-item.active { border-color: var(--cms-accent); box-shadow: 0 0 0 2px rgba(34,94,168,.12); }
.cms-empty-state { background: white; border: 1px dashed var(--cms-line); border-radius: 12px; padding: 2rem; color: var(--cms-subtle); }
.hidden { display: none !important; }
.recipe-form { display: grid; gap: 1rem; }
.cms-title-wrap, .cms-meta-edit-wrap, .cms-edit-section { border: 2px solid rgba(34,94,168,.35); border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,.03); }
.cms-title-wrap, .cms-meta-edit-wrap { background: white; padding: 1rem; }
.cms-edit-section { background: white; padding: 0 1rem 1rem 1rem; }
.cms-field-label, .cms-meta-banner, .cms-editor-hint { color: var(--cms-accent); font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }
.cms-editor-hint { padding: .2rem 0 .75rem 0; }
.title-input, .cms-meta-edit input, .ingredient-input { width: 100%; box-sizing: border-box; border:1px solid var(--cms-line); border-radius:8px; padding:.55rem .65rem; }
.meta-grid.cms-meta-edit-wrap { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; }
.cms-meta-edit { display:block; }
.cms-meta-edit strong { display:block; margin-bottom:.35rem; }
.cms-meta-edit span { display:block; }
.cms-rich-editor { min-height: 140px; outline: none; }
.cms-rich-editor:focus { box-shadow: inset 0 0 0 2px rgba(34,94,168,.15); border-radius: 6px; }
.cms-rich-editor figure { margin: 1rem 0; }
.cms-rich-editor figcaption { color: #6b7280; font-size: .92rem; }
.ingredients-editor { width:100%; border-collapse:collapse; }
.ingredients-editor th, .ingredients-editor td { border-bottom:1px solid #e6e8ec; padding:.45rem; }
.row-remove { background: transparent; border: 0; color: #a61b1b; cursor:pointer; font-size: 1.1rem; }
.cms-upload-box { display:grid; gap:.5rem; margin-bottom:.75rem; }
.images-panel { display:grid; gap:.7rem; }
.image-card { background:white; border:1px solid var(--cms-line); border-radius:10px; padding:.5rem; cursor:pointer; }
.image-card img { width:100%; height:auto; display:block; border-radius:6px; }
.filename { margin-top:.35rem; font-size:.82rem; color:#475467; word-break:break-word; }
button { border:1px solid #2e6db4; background:#2e6db4; color:white; border-radius:8px; padding:.55rem .8rem; cursor:pointer; }
button.cms-secondary { background: white; color: #1d4f89; }
button:disabled { opacity:.55; cursor: default; }
@media (max-width: 1200px) { .cms-app-layout { grid-template-columns: 250px minmax(0,1fr); } .cms-sidebar-right { grid-column: 1 / -1; min-height: auto; } }
@media (max-width: 860px) { .cms-app-layout { grid-template-columns: 1fr; } }

.recipe-item { color:#16324f !important; font-weight:600; }
.image-card { text-align:left; }
.image-card img { width:100%; max-height:110px; object-fit:cover; }
.cms-rich-editor img { max-width: min(380px, 48%); height:auto; display:block; }
.cms-rich-editor figure.step-photo, .cms-rich-editor figure { width: fit-content; max-width: 48%; }
.cms-rich-editor figure.step-photo-large { max-width: 48%; }
.cms-rich-editor figure figcaption { display:block; }


/* Build 4: separazione più netta CMS/sito */
.cms-body { color: #1f2937; }
.cms-topbar, .cms-sidebar { font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
.cms-editor-shell { overflow: auto; }
.cms-side-head { display:flex; align-items:baseline; justify-content:space-between; gap:.5rem; margin-bottom:.75rem; }
.cms-side-count { font-size:.82rem; color:#64748b; }
.recipes-list { display:grid; gap:.35rem; }
.recipe-item {
  display:block; width:100%; text-align:left; padding:.55rem .7rem;
  border:1px solid #d8e0ea; background:#fff; color:#16324f !important;
  border-radius:10px; font-weight:600; line-height:1.25;
}
.recipe-item:hover { background:#f5f9ff; border-color:#b7c8de; }
.recipe-item.active { background:#eaf3ff; border-color:#2e6db4; color:#0f3d6d !important; }
.image-card { display:grid; grid-template-columns: 88px 1fr; gap:.65rem; align-items:center; min-height:96px; }
.image-card img {
  width:88px !important; height:88px !important; object-fit:cover; border-radius:8px; border:1px solid #d8e0ea;
}
.filename { margin-top:0; font-size:.84rem; color:#334155; }
.cms-rich-editor {
  min-height: 180px; overflow: visible; background:#fff;
}
.cms-rich-editor > *:first-child { margin-top: 0; }
.cms-rich-editor > *:last-child { margin-bottom: 0; }
.cms-rich-editor figure,
.cms-rich-editor figure.step-photo,
.cms-rich-editor figure.step-photo-large {
  display:block; width: fit-content; max-width:min(360px, 46%); margin: .85rem 0;
}
.cms-rich-editor figure img,
.cms-rich-editor figure.step-photo img,
.cms-rich-editor figure.step-photo-large img {
  display:block; max-width:100%; width:auto; height:auto; border-radius:8px;
}
.cms-rich-editor img {
  display:inline-block; max-width:min(220px, 42%); height:auto; vertical-align:middle;
}
.cms-rich-editor li img {
  max-width:160px; margin: .2rem .45rem .2rem .2rem;
}
.cms-rich-editor figcaption {
  display:block; margin-top:.35rem; color:#667085; font-size:.9rem; font-style:italic;
}
.cms-image-help { font-size:.8rem; color:#64748b; margin-top:-.15rem; margin-bottom:.6rem; }
