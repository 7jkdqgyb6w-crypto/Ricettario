:root {
  --cms-bg: #f4f6fa;
  --cms-panel: #ffffff;
  --cms-line: #cfd7e6;
  --cms-accent: #225ea8;
  --cms-subtle: #667085;
}

body.cms-body {
  margin: 0;
  background: var(--cms-bg);
  color: #1f2937;
}

.cms-topbar,
.cms-topbar *,
.cms-sidebar,
.cms-sidebar *,
.cms-editor-hint,
.cms-meta-banner,
.cms-field-label,
.cms-subtle,
button,
input,
textarea {
  font-family: Arial, Helvetica, sans-serif !important;
}

.cms-topbar {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
  padding: 1rem 1.25rem;
  background: #16324f;
  color: white;
}
.cms-title { margin: 0 0 .35rem 0; font-size: 1.25rem; color: white; }
.cms-subtle { margin: 0; color: #d7deea; font-size: .92rem; }
.cms-topbar code { color: #fff; background: rgba(255,255,255,.12); padding: .1rem .35rem; border-radius: .3rem; }

.cms-app-layout { display: grid; grid-template-columns: 280px minmax(0,1fr) 320px; gap: 1rem; padding: 1rem; }
.cms-sidebar, .cms-editor-shell { min-height: calc(100vh - 120px); }
.cms-sidebar {
  background: var(--cms-panel);
  border: 1px solid var(--cms-line);
  border-radius: 12px;
  padding: 1rem;
  overflow: auto;
}
.cms-editor-shell { overflow: auto; }
.cms-side-title { margin-top: 0; font-size: 1rem; }
.cms-side-head { display:flex; align-items:baseline; justify-content:space-between; gap:.5rem; margin-bottom:.75rem; }
.cms-side-count { font-size:.82rem; color:#64748b; }
.recipes-list { display:grid; gap:.35rem; }
.recipe-item {
  display:block; width:100%; text-align:left; padding:.55rem .7rem;
  border:1px solid #d8e0ea; background:#fff; color:#16324f !important;
  border-radius:10px; font-weight:600; line-height:1.25; cursor:pointer;
}
.recipe-item:hover { background:#f5f9ff; border-color:#b7c8de; }
.recipe-item.active { background:#eaf3ff; border-color:#2e6db4; color:#0f3d6d !important; }

.cms-empty-state { background: white; border: 1px dashed var(--cms-line); border-radius: 12px; padding: 2rem; color: var(--cms-subtle); }
.hidden { display: none !important; }
.recipe-form { display: grid; gap: 1rem; }
.cms-toolbar { display:flex; align-items:center; gap:.8rem; }
.cms-toolbar-slug { color:#475467; font: .9rem Arial, Helvetica, sans-serif; }
.cms-title-wrap, .cms-meta-edit-wrap, .cms-edit-section { border: 2px solid rgba(34,94,168,.35); border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,.03); }
.cms-title-wrap, .cms-meta-edit-wrap { background: white; padding: 1rem; }
.cms-edit-section { background: white; padding: 0 1rem 1rem 1rem; }
.cms-field-label, .cms-editor-hint { color: var(--cms-accent); font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }
.cms-editor-hint { padding: .2rem 0 .75rem 0; }
.title-input, .cms-meta-edit input, .ingredient-input, .cms-form-row input, .cms-form-row textarea { width: 100%; box-sizing: border-box; border:1px solid var(--cms-line); border-radius:8px; padding:.55rem .65rem; }
.meta-grid.cms-meta-edit-wrap { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; }
.cms-meta-edit strong { display:block; margin-bottom:.35rem; }
.cms-rich-editor { min-height: 180px; outline: none; overflow: visible; background:#fff; }
.cms-rich-editor:focus { box-shadow: inset 0 0 0 2px rgba(34,94,168,.15); border-radius: 6px; }
.cms-rich-editor.active-editor { box-shadow: inset 0 0 0 2px rgba(34,94,168,.18); border-radius: 8px; }
.cms-rich-editor.drag-target { box-shadow: inset 0 0 0 3px rgba(34,94,168,.35); background: #f7fbff; }
.cms-rich-editor > *:first-child { margin-top: 0; }
.cms-rich-editor > *:last-child { margin-bottom: 0; }

.ingredients-editor { width:100%; border-collapse:collapse; }
.ingredients-editor th, .ingredients-editor td { border-bottom:1px solid #e6e8ec; padding:.45rem; }
.row-remove { background: transparent; border: 0; color: #a61b1b; cursor:pointer; font-size: 1.1rem; }

button { border:1px solid #2e6db4; background:#2e6db4; color:white; border-radius:8px; padding:.55rem .8rem; cursor:pointer; }
button.cms-secondary { background: white; color: #1d4f89; }
button:disabled { opacity:.55; cursor: default; }

.cms-drop-guide { display:grid; gap:.8rem; }
.cms-drop-title { margin:0; color:#16324f; font-weight:700; }
.cms-drop-note { color:#475467 !important; }
.cms-upload-box { display:grid; gap:.5rem; margin-bottom:.75rem; }
.images-panel { display:grid; gap:.7rem; margin-top:.8rem; }
.image-card {
  display:grid; grid-template-columns: 88px 1fr; gap:.65rem; align-items:center; min-height:96px;
  background:white; border:1px solid var(--cms-line); border-radius:10px; padding:.5rem; cursor:pointer; text-align:left;
}
.image-card img {
  width:88px !important; height:88px !important; object-fit:cover; border-radius:8px; border:1px solid #d8e0ea;
}
.filename { margin-top:0; font-size:.84rem; color:#334155; word-break:break-word; }
.image-card-help { font-size:.8rem; color:#64748b; margin-top:.2rem; }

.image-inspector {
  margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--cms-line);
  display:grid; gap:.8rem;
}
.image-inspector h3 { margin: 0; font-size: 1rem; }
.cms-form-row { display:grid; gap:.3rem; }
.cms-form-row label { color:#16324f; font-size:.86rem; font-weight:700; }
.cms-inspector-actions { display:flex; gap:.6rem; flex-wrap:wrap; }

.cms-rich-editor figure,
.cms-rich-editor figure.step-photo,
.cms-rich-editor figure.step-photo-large,
.cms-rich-editor figure.cms-inline-figure {
  float: right;
  clear: none;
  width: fit-content;
  max-width: min(280px, 42%);
  margin: .2rem 0 .8rem 1rem;
}
.cms-rich-editor figure img,
.cms-rich-editor figure.step-photo img,
.cms-rich-editor figure.step-photo-large img,
.cms-rich-editor figure.cms-inline-figure img {
  display:block; max-width:100%; width:auto; height:auto; border-radius:8px;
}
.cms-rich-editor img { display:inline-block; max-width:min(220px, 42%); height:auto; vertical-align:middle; }
.cms-rich-editor figcaption { display:block; margin-top:.35rem; color:#667085; font-size:.9rem; font-style:italic; }
.cms-rich-editor figure.selected-figure { outline: 3px solid rgba(34,94,168,.35); border-radius: 8px; }

@media (max-width: 1200px) {
  .cms-app-layout { grid-template-columns: 250px minmax(0,1fr); }
  .cms-sidebar-right { grid-column: 1 / -1; min-height: auto; }
}
@media (max-width: 860px) {
  .cms-app-layout { grid-template-columns: 1fr; }
  .meta-grid.cms-meta-edit-wrap { grid-template-columns: 1fr; }
}


/* build7 fixes */
.cms-app-layout { grid-template-columns: 240px minmax(0,1fr) 280px; align-items:start; }
.cms-sidebar-right { position: sticky; top: 1rem; align-self: start; max-height: calc(100vh - 2rem); }
.cms-meta-edit input, .ingredient-input, .cms-form-row input, .cms-form-row textarea, .title-input { color:#111 !important; background:#fff !important; }
.cms-rich-editor figure,
.cms-rich-editor figure.step-photo,
.cms-rich-editor figure.step-photo-large,
.cms-rich-editor figure.cms-inline-figure { float:right; clear:none; max-width:min(280px,42%); margin:.2rem 0 .8rem 1rem; position:relative; }
.cms-rich-editor figure img, .cms-rich-editor figure.step-photo img, .cms-rich-editor figure.step-photo-large img, .cms-rich-editor figure.cms-inline-figure img { width:100%; height:auto; }
.cms-rich-editor figure.selected-figure::after { content:"Immagine selezionata"; position:absolute; left:0; top:-1.4rem; font:12px Arial,Helvetica,sans-serif; color:#225ea8; background:#fff; padding:0 .3rem; }
@media (max-width: 1024px) { .cms-app-layout { grid-template-columns: 220px minmax(0,1fr); } .cms-sidebar-right { grid-column:1/-1; position:static; max-height:none; } }
