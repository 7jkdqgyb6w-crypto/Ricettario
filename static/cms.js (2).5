const state = {
  currentSlug: null,
  activeEditor: null,
  currentDropRange: null,
  selectedFigure: null,
}

function toSiteAbsoluteUrl(src, slug) {
  if (!src) return src
  if (src.startsWith('/site/')) return src
  if (src.startsWith('http://') || src.startsWith('https://') || src.startsWith('data:')) return src
  const clean = src.split('?')[0].split('#')[0]
  const filename = clean.split('/').pop()
  return `/site/foto/${slug}/${filename}`
}

function normalizeEditorHtml(html, slug) {
  const wrapper = document.createElement('div')
  wrapper.innerHTML = html || ''
  wrapper.querySelectorAll('img').forEach((img) => {
    img.setAttribute('src', toSiteAbsoluteUrl(img.getAttribute('src'), slug))
  })
  return wrapper.innerHTML
}

function denormalizeEditorHtml(html, slug) {
  const wrapper = document.createElement('div')
  wrapper.innerHTML = html || ''
  wrapper.querySelectorAll('img').forEach((img) => {
    const src = img.getAttribute('src') || ''
    if (src.includes(`/site/foto/${slug}/`)) {
      const filename = src.split('/').pop()
      img.setAttribute('src', `../../foto/${slug}/${filename}`)
    }
  })
  wrapper.querySelectorAll('figure').forEach((figure) => {
    figure.classList.remove('selected-figure')
  })
  return wrapper.innerHTML
}

const recipesList = document.getElementById('recipesList')
const recipesCount = document.getElementById('recipesCount')
const recipeForm = document.getElementById('recipeForm')
const emptyState = document.getElementById('emptyState')
const saveButton = document.getElementById('saveButton')
const addIngredientRowButton = document.getElementById('addIngredientRow')
const ingredientsBody = document.getElementById('ingredientsBody')
const imageUpload = document.getElementById('imageUpload')
const uploadButton = document.getElementById('uploadButton')
const imagesPanel = document.getElementById('imagesPanel')
const currentSlugLabel = document.getElementById('currentSlugLabel')

const imageInspector = document.getElementById('imageInspector')
const imageAlt = document.getElementById('imageAlt')
const imageCaption = document.getElementById('imageCaption')
const imageWidth = document.getElementById('imageWidth')
const applyImageMeta = document.getElementById('applyImageMeta')
const removeImageFromText = document.getElementById('removeImageFromText')
const moveImageLeft = document.getElementById('moveImageLeft')
const moveImageRight = document.getElementById('moveImageRight')

const editors = [
  document.getElementById('editorIntroduzione'),
  document.getElementById('editorPreparazione'),
  document.getElementById('editorNote'),
]

function escapeHtml(value) {
  return (value || '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
}

function createIngredientRow(row = {}) {
  const tr = document.createElement('tr')
  tr.innerHTML = `
    <td><input class="ingredient-input" data-key="ingrediente" value="${escapeHtml(row.ingrediente || '')}"></td>
    <td><input class="ingredient-input" data-key="quantita" value="${escapeHtml(row.quantita || '')}"></td>
    <td><input class="ingredient-input" data-key="unita" value="${escapeHtml(row.unita || '')}"></td>
    <td><input class="ingredient-input" data-key="note" value="${escapeHtml(row.note || '')}"></td>
    <td><button type="button" class="row-remove" title="Elimina">×</button></td>
  `
  tr.querySelector('.row-remove').addEventListener('click', () => tr.remove())
  ingredientsBody.appendChild(tr)
}

function setActiveEditor(editor) {
  state.activeEditor = editor
  editors.forEach((node) => node.classList.toggle('active-editor', node === editor))
}

function rememberCurrentRange() {
  const sel = window.getSelection()
  if (!sel || !sel.rangeCount) return
  const range = sel.getRangeAt(0)
  if (!state.activeEditor || !state.activeEditor.contains(range.startContainer)) return
  state.currentDropRange = range.cloneRange()
}

function restoreRange() {
  if (!state.currentDropRange) return false
  const sel = window.getSelection()
  sel.removeAllRanges()
  sel.addRange(state.currentDropRange)
  return true
}

function placeCaretFromPoint(editor, event) {
  let range = null
  if (document.caretRangeFromPoint) {
    range = document.caretRangeFromPoint(event.clientX, event.clientY)
  } else if (event.rangeParent) {
    range = document.createRange()
    range.setStart(event.rangeParent, event.rangeOffset)
  }
  if (range && editor.contains(range.startContainer)) {
    const sel = window.getSelection()
    sel.removeAllRanges()
    sel.addRange(range)
    state.currentDropRange = range.cloneRange()
  }
}

function createFigureElement(url, filename, options = {}) {
  const figure = document.createElement('figure')
  figure.className = 'cms-inline-figure'
  figure.setAttribute('tabindex', '0')
  figure.style.cssText = 'float:right; clear:none; margin:.2rem 0 .8rem 1rem;'
  if (options.width) {
    figure.style.maxWidth = `${options.width}px`
  }
  const img = document.createElement('img')
  img.src = url
  img.style.width = '100%'
  img.style.height = 'auto'
  img.alt = options.alt || ''
  img.dataset.filename = filename || url.split('/').pop()
  figure.appendChild(img)
  const caption = document.createElement('figcaption')
  caption.textContent = options.caption || ''
  figure.appendChild(caption)
  return figure
}

function insertNodeAtSelection(node) {
  const editor = state.activeEditor
  if (!editor) return
  editor.focus()
  restoreRange()
  const sel = window.getSelection()
  if (!sel || !sel.rangeCount) return
  const range = sel.getRangeAt(0)
  range.deleteContents()
  range.insertNode(node)
  const paragraph = document.createElement('p')
  paragraph.innerHTML = '<br>'
  if (node.parentNode) {
    node.parentNode.insertBefore(paragraph, node.nextSibling)
  }
  const newRange = document.createRange()
  newRange.setStart(paragraph, 0)
  newRange.collapse(true)
  sel.removeAllRanges()
  sel.addRange(newRange)
  state.currentDropRange = newRange.cloneRange()
  attachFigureHandlers(editor)
  selectFigure(node)
}

function insertImageReference(url, filename) {
  const figure = createFigureElement(url, filename)
  insertNodeAtSelection(figure)
}

async function uploadDroppedFile(file) {
  if (!state.currentSlug) return
  const formData = new FormData()
  formData.append('slug', state.currentSlug)
  formData.append('image', file, file.name)
  const response = await fetch('/api/upload-image', { method: 'POST', body: formData })
  const data = await response.json()
  if (!response.ok) throw new Error(data.error || 'Upload non riuscito')
  return data
}

async function importSelectedFiles(insertAfter = false) {
  const files = [...(imageUpload.files || [])]
  if (!files.length || !state.currentSlug) return
  for (const file of files) {
    const data = await uploadDroppedFile(file)
    if (insertAfter && state.activeEditor) {
      insertImageReference(data.url, data.filename)
    }
  }
  imageUpload.value = ''
  uploadButton.disabled = true
  await refreshImagesPanel()
}

async function handleDroppedFiles(files, editor, event) {
  if (!files || !files.length) return
  setActiveEditor(editor)
  placeCaretFromPoint(editor, event)
  for (const file of files) {
    const data = await uploadDroppedFile(file)
    insertImageReference(data.url, data.filename)
  }
  await refreshImagesPanel()
}

function collectIngredients() {
  return [...ingredientsBody.querySelectorAll('tr')].map((row) => {
    const values = {}
    row.querySelectorAll('input').forEach((input) => { values[input.dataset.key] = input.value })
    return values
  }).filter((row) => Object.values(row).some((value) => value && value.trim() !== ''))
}

function clearFigureSelection() {
  editors.forEach((editor) => {
    editor.querySelectorAll('figure.selected-figure').forEach((figure) => figure.classList.remove('selected-figure'))
  })
}

function selectFigure(figure) {
  state.selectedFigure = figure
  clearFigureSelection()
  if (!figure) {
    imageInspector.classList.add('hidden')
    imageAlt.value = ''
    imageCaption.value = ''
    imageWidth.value = ''
    return
  }
  figure.classList.add('selected-figure')
  imageInspector.classList.remove('hidden')
  const img = figure.querySelector('img')
  const caption = figure.querySelector('figcaption')
  imageAlt.value = img?.getAttribute('alt') || ''
  imageCaption.value = caption?.textContent || ''
  imageWidth.value = parseInt(figure.style.maxWidth, 10) || parseInt(figure.getAttribute('data-width') || '', 10) || ''
}

function moveSelectedFigure(direction) {
  const figure = state.selectedFigure
  if (!figure) return
  if (direction < 0 && figure.previousElementSibling) {
    figure.parentNode.insertBefore(figure, figure.previousElementSibling)
  } else if (direction > 0 && figure.nextElementSibling) {
    figure.parentNode.insertBefore(figure.nextElementSibling, figure)
  }
}


function attachFigureHandlers(editor) {
  editor.querySelectorAll('figure').forEach((figure) => {
    if (figure.dataset.bound === '1') return
    figure.dataset.bound = '1'
    figure.addEventListener('click', (event) => {
      event.preventDefault()
      event.stopPropagation()
      setActiveEditor(editor)
      selectFigure(figure)
    })
  })
}

function editorClickFallback(editor, event) {
  if (event.target.closest('figure')) return
  selectFigure(null)
  setActiveEditor(editor)
  rememberCurrentRange()
}

function attachEditorBehavior(editor) {
  editor.addEventListener('focus', () => setActiveEditor(editor))
  editor.addEventListener('click', (event) => editorClickFallback(editor, event))
  editor.addEventListener('keyup', rememberCurrentRange)
  editor.addEventListener('mouseup', rememberCurrentRange)
  editor.addEventListener('dragenter', (event) => {
    event.preventDefault()
    setActiveEditor(editor)
    editor.classList.add('drag-target')
  })
  editor.addEventListener('dragover', (event) => {
    event.preventDefault()
    setActiveEditor(editor)
    placeCaretFromPoint(editor, event)
    editor.classList.add('drag-target')
  })
  editor.addEventListener('dragleave', () => editor.classList.remove('drag-target'))
  editor.addEventListener('drop', async (event) => {
    event.preventDefault()
    editor.classList.remove('drag-target')
    const files = [...(event.dataTransfer?.files || [])].filter((file) => file.type.startsWith('image/'))
    if (!files.length) return
    try {
      await handleDroppedFiles(files, editor, event)
    } catch (err) {
      alert(err.message)
    }
  })
  editor.addEventListener('paste', async (event) => {
    const items = [...(event.clipboardData?.items || [])]
    const files = items.filter((item) => item.type.startsWith('image/')).map((item) => item.getAsFile()).filter(Boolean)
    if (!files.length) return
    event.preventDefault()
    setActiveEditor(editor)
    rememberCurrentRange()
    try {
      for (const file of files) {
        const data = await uploadDroppedFile(file)
        insertImageReference(data.url, data.filename)
      }
      await refreshImagesPanel()
    } catch (err) {
      alert(err.message)
    }
  })
}

async function loadRecipes() {
  const response = await fetch('/api/recipes')
  const recipes = await response.json()
  recipesCount.textContent = `${recipes.length} ricette`
  recipesList.innerHTML = ''
  recipes.forEach((recipe) => {
    const button = document.createElement('button')
    button.type = 'button'
    button.className = 'recipe-item'
    button.textContent = recipe.title || recipe.slug
    button.dataset.slug = recipe.slug
    button.addEventListener('click', () => openRecipe(recipe.slug, button))
    recipesList.appendChild(button)
  })

  const slugFromHash = decodeURIComponent((window.location.hash || '').replace(/^#/, ''))
  if (slugFromHash) {
    const button = recipesList.querySelector(`[data-slug="${CSS.escape(slugFromHash)}"]`)
    if (button) {
      openRecipe(slugFromHash, button)
    }
  }
}

function markActive(button) {
  recipesList.querySelectorAll('.recipe-item').forEach((node) => node.classList.remove('active'))
  if (button) button.classList.add('active')
}

async function refreshImagesPanel() {
  if (!state.currentSlug) {
    imagesPanel.innerHTML = ''
    return
  }
  const response = await fetch(`/api/images?slug=${encodeURIComponent(state.currentSlug)}`)
  const images = await response.json()
  imagesPanel.innerHTML = ''
  if (!images.length) {
    imagesPanel.innerHTML = '<p class="cms-subtle">Nessuna immagine nella cartella della ricetta.</p>'
    return
  }
  images.forEach((item) => {
    const card = document.createElement('button')
    card.type = 'button'
    card.className = 'image-card'
    card.innerHTML = `
      <img src="${item.url}" alt="${escapeHtml(item.filename)}">
      <div>
        <div class="filename">${item.filename}</div>
        <div class="image-card-help">Inserisci nel punto del cursore</div>
      </div>
    `
    card.addEventListener('click', () => {
      if (!state.activeEditor) {
        alert('Prima clicca nel punto del testo dove vuoi inserire l’immagine.')
        return
      }
      insertImageReference(item.url, item.filename)
    })
    imagesPanel.appendChild(card)
  })
}

function fillMeta(data) {
  document.getElementById('autore').value = data.metadati?.autore || ''
  document.getElementById('categoria').value = data.metadati?.categoria || ''
  document.getElementById('origine').value = data.metadati?.origine || ''
  document.getElementById('fonte').value = data.metadati?.fonte || ''
}

async function openRecipe(slug, button) {
  const response = await fetch(`/api/recipe/${slug}`)
  const data = await response.json()
  if (!response.ok) { alert(data.error || 'Errore apertura ricetta'); return }
  state.currentSlug = slug
  window.location.hash = encodeURIComponent(slug)
  currentSlugLabel.textContent = slug
  document.getElementById('titolo').value = data.titolo || ''
  fillMeta(data)
  document.getElementById('editorIntroduzione').innerHTML = normalizeEditorHtml(data.introduzione, slug)
  document.getElementById('editorPreparazione').innerHTML = normalizeEditorHtml(data.preparazione, slug)
  document.getElementById('editorNote').innerHTML = normalizeEditorHtml(data.note, slug)
  editors.forEach(attachFigureHandlers)
  ingredientsBody.innerHTML = ''
  ;(data.ingredienti || []).forEach((row) => createIngredientRow(row))
  if (!ingredientsBody.children.length) createIngredientRow()
  emptyState.classList.add('hidden')
  recipeForm.classList.remove('hidden')
  saveButton.disabled = false
  markActive(button)
  setActiveEditor(document.getElementById('editorIntroduzione'))
  state.currentDropRange = null
  selectFigure(null)
  await refreshImagesPanel()
}

async function saveCurrentRecipe() {
  if (!state.currentSlug) return
  const payload = {
    titolo: document.getElementById('titolo').value,
    metadati: {
      autore: document.getElementById('autore').value,
      categoria: document.getElementById('categoria').value,
      origine: document.getElementById('origine').value,
      fonte: document.getElementById('fonte').value,
    },
    introduzione: denormalizeEditorHtml(document.getElementById('editorIntroduzione').innerHTML, state.currentSlug),
    ingredienti: collectIngredients(),
    preparazione: denormalizeEditorHtml(document.getElementById('editorPreparazione').innerHTML, state.currentSlug),
    note: denormalizeEditorHtml(document.getElementById('editorNote').innerHTML, state.currentSlug),
  }
  const response = await fetch(`/api/recipe/${state.currentSlug}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  })
  const data = await response.json()
  if (!response.ok) { alert(data.error || 'Errore salvataggio'); return }
  await loadRecipes()
  const button = recipesList.querySelector(`[data-slug="${CSS.escape(state.currentSlug)}"]`)
  if (button) {
    await openRecipe(state.currentSlug, button)
  }
  alert('Ricetta salvata.')
}

addIngredientRowButton.addEventListener('click', () => createIngredientRow())
saveButton.addEventListener('click', saveCurrentRecipe)
editors.forEach(attachEditorBehavior)

if (imageUpload) {
  imageUpload.addEventListener('change', () => {
    uploadButton.disabled = !imageUpload.files.length || !state.currentSlug
  })
}
if (uploadButton) {
  uploadButton.addEventListener('click', async () => {
    if (!state.currentSlug) return
    try {
      await importSelectedFiles(false)
    } catch (err) {
      alert(err.message)
    }
  })
}

applyImageMeta.addEventListener('click', () => {
  const figure = state.selectedFigure
  if (!figure) return
  const img = figure.querySelector('img')
  const caption = figure.querySelector('figcaption') || figure.appendChild(document.createElement('figcaption'))
  if (img) img.setAttribute('alt', imageAlt.value)
  caption.textContent = imageCaption.value
  const widthValue = parseInt(imageWidth.value, 10)
  if (widthValue) {
    figure.style.maxWidth = `${widthValue}px`
    figure.setAttribute('data-width', String(widthValue))
  } else {
    figure.style.maxWidth = ''
    figure.removeAttribute('data-width')
  }
})

if (moveImageLeft) moveImageLeft.addEventListener('click', () => moveSelectedFigure(-1))
if (moveImageRight) moveImageRight.addEventListener('click', () => moveSelectedFigure(1))

removeImageFromText.addEventListener('click', () => {
  const figure = state.selectedFigure
  if (!figure) return
  figure.remove()
  selectFigure(null)
})

window.addEventListener('hashchange', () => {
  const slug = decodeURIComponent((window.location.hash || '').replace(/^#/, ''))
  if (!slug || slug === state.currentSlug) return
  const button = recipesList.querySelector(`[data-slug="${CSS.escape(slug)}"]`)
  if (button) openRecipe(slug, button)
})

loadRecipes()
